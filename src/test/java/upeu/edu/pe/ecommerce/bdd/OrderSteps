package upeu.edu.pe.ecommerce.bdd;

import io.cucumber.java.en.When;
import io.cucumber.java.en.Then;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.web.server.LocalServerPort;
import org.springframework.http.ResponseEntity;
import org.springframework.web.client.RestTemplate;
import upeu.edu.pe.ecommerce.app.service.OrderService;
import upeu.edu.pe.ecommerce.infrastructure.entity.OrderEntity;

import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertTrue;

public class OrderSteps {

    @LocalServerPort
    private int port;

    @Autowired
    private OrderService orderService;

    private ResponseEntity<String> response;
    private RestTemplate restTemplate = new RestTemplate();

    @When("I submit the checkout request to finalize the order")
    public void i_submit_the_checkout_request_to_finalize_the_order() {
        // Ajustado al endpoint real y usando GET, tal como figura en tu OrderController
        String url = "http://localhost:" + port + "/user/order/create-order"; 
        
        // Ejecutamos la petición GET. Recibimos String porque tu método retorna una redirección de vista
        response = restTemplate.getForEntity(url, String.class);
    }

    @Then("the order should be successfully recorded in the system")
    public void the_order_should_be_successfully_recorded_in_the_system() {
        // Validamos que la respuesta del servidor no sea nula
        assertNotNull(response);
        
        // Verificamos directamente en el servicio que la orden se persistió en la BD
        Iterable<OrderEntity> orders = orderService.getOrders();
        assertNotNull(orders);
        
        // Validamos que al menos exista una orden registrada en el sistema
        assertTrue(orders.iterator().hasNext(), "La base de datos debería tener la orden que acabamos de crear");
    }
}