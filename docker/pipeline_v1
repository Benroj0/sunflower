pipeline {
    agent any

    tools {
        maven 'MAVEN_HOME'
    }

    environment {
        // Nombres completamente aislados para evitar conflictos con la clase
        DOCKER_PROJECT_NAME = 'sunflowerapp'
        APP_CONTAINER_NAME = 'sunflower_web_app'
        DB_CONTAINER_NAME = 'sunflower_db_mysql'
        SONARQUBE_URL = 'http://sonarqube:9000'
        SONARQUBE_TOKEN = credentials('Sonarqube')
    }

    stages {
        // 📥 Etapa 1: Limpieza del espacio de trabajo y descarga desde GitHub
        stage('Checkout') {
            steps {
                cleanWs() 
                checkout scm
            }
        }

        // 🧪 Etapa 2: Pruebas automatizadas de la tienda (Unitarias y BDD)
        stage('Test') {
            steps {
                echo '🧪 === ETAPA 2: EJECUCIÓN DE PRUEBAS AUTOMATIZADAS ==='
                sh 'mvn test'
            }
        }

        // 🔨 Etapa 3: Empaquetado del archivo ejecutable (JAR)
        stage('Build') {
            steps {
                echo '🔨 === ETAPA 3: COMPILACIÓN (BUILD) ==='
                sh 'mvn package -DskipTests' 
            }
        }

        // 📊 Etapa 4: Inspección continua en SonarQube
        stage('SonarQube Analysis') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    echo '📊 === ETAPA 4: ANÁLISIS DE CALIDAD CON SONARQUBE ==='
                    withSonarQubeEnv('sonarqube') {
                        sh '''
                            mvn sonar:sonar \
                                -Dsonar.host.url=${SONARQUBE_URL} \
                                -Dsonar.login=${SONARQUBE_TOKEN} \
                                -Dsonar.projectKey=ecommerce-lp2 \
                                -Dsonar.projectName="E-commerce LP2" \
                                -Dsonar.projectVersion=${BUILD_NUMBER} \
                                -Dsonar.sources=src/main \
                                -Dsonar.tests=src/test \
                                -Dsonar.java.binaries=target/classes
                        '''
                    }
                }
            }
        }

        // 🚀 Etapa 5: Construcción y despliegue del contenedor aislado
        stage('Docker Build & Deploy') {
            steps {
                echo '🚀 === ETAPA 5: DESPLIEGUE CON DOCKER-COMPOSE (ENTORNO SUNFLOWER) ==='
                script {
                    echo '🧹 Eliminando contenedores antiguos de Sunflower para evitar colisiones...'
                    sh "docker rm -f ${APP_CONTAINER_NAME} || true"
                    sh "docker rm -f ${DB_CONTAINER_NAME} || true"
                }
                dir('docker') {
                    script {
                        echo '🧹 Deteniendo servicios previos del stack Sunflower...'
                        sh "docker-compose -p ${DOCKER_PROJECT_NAME} down -v --remove-orphans || true"
                        
                        echo '🏗️ Levantando el nuevo stack de forma completamente independiente...'
                        sh "docker-compose -p ${DOCKER_PROJECT_NAME} up -d --build"
                    }
                }
            }
        }

        // 🏥 Etapa 6: Verificación de disponibilidad de la tienda
        stage('Health Check') {
            steps {
                echo '🏥 === ETAPA 6: VERIFICACIÓN DE SALUD (HEALTH CHECK) ==='
                script {
                    sh '''
                        echo "⏳ Esperando 20 segundos iniciales para el arranque interno de Spring Boot..."
                        sleep 20
                        
                        COUNTER=1
                        while [ $COUNTER -le 15 ]; do
                            if curl -f http://host.docker.internal:8081/home > /dev/null 2>&1; then
                                echo "✅ ¡Excelente! La tienda Sunflower está respondiendo con éxito hacia el exterior."
                                exit 0
                            fi
                            echo "Intento $COUNTER de 15... La app aún está cargando, reintentando en 5 segundos..."
                            COUNTER=$((COUNTER + 1))
                            sleep 5
                        done
                        echo "❌ El Health Check falló: La aplicación no respondió en el puerto 8081."
                        exit 1
                    '''
                }
            }
        }
    }

    post {
        success {
            echo '🎉 ¡TODO EL PIPELINE DE CI/CD HA COMPLETADO CON ÉXITO!'
            echo '🌐 Tu app está lista y disponible en: http://localhost:8081/home'
        }
        failure {
            echo '💥 El proceso falló en alguna etapa. Aplicando apagado de seguridad...'
            dir('docker') {
                sh "docker-compose -p ${DOCKER_PROJECT_NAME} down -v || true"
            }
        }
    }
}