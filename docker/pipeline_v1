pipeline {
    agent any

    tools {
        maven 'MAVEN_HOME'
    }

    environment {
        DOCKER_PROJECT_NAME = 'ecomapp'
        APP_CONTAINER_NAME = 'ecommerce_app'
        DB_CONTAINER_NAME = 'ecommerce_mysql'
        DB_NAME = 'ecommerce_db'
        DB_USER = 'root'
        DB_PASSWORD = 'benja'
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    echo '🔨 === INICIO: BUILD ==='
                    sh 'mvn -DskipTests clean package'
                    echo '✅ === FIN: BUILD ==='
                }
            }
        }

        stage('Sonar Analysis') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    echo '📊 === INICIO: SONAR ANALYSIS ==='
                    withSonarQubeEnv('sonarqube') {
                        sh '''
                            mvn sonar:sonar \
                                -Dsonar.projectKey=ecommerce-lp2 \
                                -Dsonar.projectName="E-commerce LP2" \
                                -Dsonar.projectVersion=${BUILD_NUMBER} \
                                -Dsonar.sources=src/main \
                                -Dsonar.tests=src/test \
                                -Dsonar.java.binaries=target/classes
                        '''
                    }
                    echo '✅ === FIN: SONAR ANALYSIS ==='
                }
            }
        }

        stage('Deploy Application') {
            steps {
                echo '🚀 === INICIO: DESPLIEGUE ==='
                dir('docker') {
                    script {
                        echo '1️⃣ Limpiando despliegue anterior...'
                        sh "docker-compose -p ${DOCKER_PROJECT_NAME} down -v --remove-orphans || true"

                        echo '2️⃣ Construyendo e iniciando servicios...'
                        sh "docker-compose -p ${DOCKER_PROJECT_NAME} up -d --build"
                    }
                }
                echo '✅ === FIN: DESPLIEGUE ==='
            }
        }

        stage('Health Check') {
            steps {
                echo '🏥 === INICIO: HEALTH CHECK ==='
                sleep time: 10, unit: 'SECONDS'
                sh '''
                    for i in {1..15}; do
                        if curl -f http://localhost:8081/home > /dev/null 2>&1; then
                            echo "✅ Aplicación respondiendo en puerto 8081"
                            exit 0
                        fi
                        echo "Intento $i de 15..."
                        sleep 3
                    done
                    echo "❌ La aplicación no responde después de 15 intentos"
                    exit 1
                '''
            }
        }
    }

    post {
        success {
            echo '🎉 ✨ Pipeline completado exitosamente'
        }
        failure {
            echo '💥 ✗ Pipeline falló'
            dir('docker') {
                sh 'docker-compose -p ${DOCKER_PROJECT_NAME} logs || true'
                sh 'docker-compose -p ${DOCKER_PROJECT_NAME} down -v || true'
            }
        }
        always {
            echo '🏁 === FINALIZACIÓN ==='
            cleanWs()
        }
    }
}
