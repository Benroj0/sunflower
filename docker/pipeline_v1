pipeline {
    agent any // Si falla aquí, cámbialo por agent { label 'tu-nodo-jenkins' }

    tools {
        maven 'MAVEN_HOME'
    }

    environment {
        DOCKER_PROJECT_NAME = 'ecomapp'
        // Definimos el ID de las credenciales de Sonar que creaste en Jenkins
        SONAR_CRED_ID = 'sonarqube-token' 
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo '🔨 === INICIO: BUILD ==='
                sh 'mvn -DskipTests clean package'
            }
        }

        stage('Sonar Analysis') {
            steps {
                // Usamos withSonarQubeEnv para cargar la configuración del servidor
                withSonarQubeEnv('sonarqube') {
                    // Usamos withCredentials para el token de forma segura
                    withCredentials([string(credentialsId: "${SONAR_CRED_ID}", variable: 'SONAR_TOKEN')]) {
                        // IMPORTANTE: Usamos comillas triples DOBLES (""") para que la interpolación funcione
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.host.url=\$SONAR_HOST_URL \
                                -Dsonar.login=${SONAR_TOKEN} \
                                -Dsonar.projectKey=ecommerce-lp2 \
                                -Dsonar.projectName="E-commerce LP2" \
                                -Dsonar.projectVersion=${BUILD_NUMBER} \
                                -Dsonar.sources=src/main \
                                -Dsonar.tests=src/test \
                                -Dsonar.java.binaries=target/classes
                        """
                    }
                }
            }
        }

        stage('Deploy Application') {
            steps {
                echo '🚀 === INICIO: DESPLIEGUE ==='
                dir('docker') {
                    // Limpieza forzada y estricta
                    sh "docker-compose -p ${DOCKER_PROJECT_NAME} down -v --remove-orphans || true"
                    sh "docker system prune -f || true" // Limpieza preventiva de caché
                    
                    // Despliegue
                    sh "docker-compose -p ${DOCKER_PROJECT_NAME} up -d --build"
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    echo '🏥 === INICIO: HEALTH CHECK ==='
                    timeout(time: 2, unit: 'MINUTES') {
                        waitUntil {
                            def status = sh(script: "curl -s -o /dev/null -w '%{http_code}' http://localhost:8081/home", returnStdout: true).trim()
                            return status == '200'
                        }
                    }
                    echo "✅ Aplicación levantada exitosamente"
                }
            }
        }
    }

    post {
        failure {
            echo '💥 ✗ Pipeline falló. Limpiando...'
            dir('docker') {
                sh "docker-compose -p ${DOCKER_PROJECT_NAME} down -v || true"
            }
        }
        always {
            cleanWs()
        }
    }
}