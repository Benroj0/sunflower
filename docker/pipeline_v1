pipeline {
    agent any

    tools {
        maven 'MAVEN_HOME'
    }

    environment {
        DOCKER_PROJECT_NAME = 'ecomapp'
        APP_CONTAINER_NAME = 'ecommerce_app'
        SONARQUBE_URL = 'http://sonarqube:9000'
        SONARQUBE_TOKEN = credentials('sonarqube-token')
    }

    stages {
        // 📥 Etapa 1: Limpieza segura del espacio de trabajo y clonación de Git
        stage('Checkout') {
            steps {
                cleanWs() 
                checkout scm
            }
        }

        // 🧪 Etapa 2: Ejecución de tus pruebas unitarias y Cucumber
        stage('Test') {
            steps {
                echo '🧪 === ETAPA 2: EJECUCIÓN DE PRUEBAS AUTOMATIZADAS ==='
                sh 'mvn test'
            }
        }

        // 🔨 Etapa 3: Compilación y empaquetado del archivo .jar
        stage('Build') {
            steps {
                echo '🔨 === ETAPA 3: COMPILACIÓN (BUILD) ==='
                sh 'mvn package -DskipTests' 
            }
        }

        // 📊 Etapa 4: Análisis estático de código enviando métricas a SonarQube
        stage('SonarQube Analysis') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    echo '📊 === ETAPA 4: ANÁLISIS DE CALIDAD CON SONARQUBE ==='
                    withSonarQubeEnv('sonarqube') {
                        sh '''
                            mvn sonar:sonar \
                                -Dsonar.host.url=${SONARQUBE_URL} \
                                -Dsonar.login=${SONARQUBE_TOKEN} \
                                -Dsonar.projectKey=ecommerce-lp2 \
                                -Dsonar.projectName="E-commerce LP2" \
                                -Dsonar.projectVersion=${BUILD_NUMBER} \
                                -Dsonar.sources=src/main \
                                -Dsonar.tests=src/test \
                                -Dsonar.java.binaries=target/classes
                        '''
                    }
                }
            }
        }

        // 🚀 Etapa 5: Despliegue automático de contenedores (App + MySQL)
        stage('Docker Build & Deploy') {
            steps {
                echo '🚀 === ETAPA 5: DESPLIEGUE CON DOCKER-COMPOSE ==='
                dir('docker') {
                    script {
                        sh "docker-compose -p ${DOCKER_PROJECT_NAME} down -v --remove-orphans || true"
                        sh "docker-compose -p ${DOCKER_PROJECT_NAME} up -d --build"
                    }
                }
            }
        }

        // 🏥 Etapa 6: Verificación de disponibilidad de la plataforma web
        stage('Health Check') {
            steps {
                echo '🏥 === ETAPA 6: VERIFICACIÓN DE SALUD (HEALTH CHECK) ==='
                script {
                    sh '''
                        sleep 15
                        for i in {1..15}; do
                            if curl -f http://localhost:8081/home > /dev/null 2>&1; then
                                echo "✅ ¡Perfecto! La tienda Sunflower está respondiendo con éxito."
                                exit 0
                            fi
                            echo "Intento $i de 15... Esperando que el servidor Spring Boot inicie"
                            sleep 5
                        done
                        exit 1
                    '''
                }
            }
        }
    }

    post {
        success {
            echo '🎉 ¡Todo el pipeline de CI/CD ha finalizado con éxito!'
            echo '🌐 Tu app está lista en: http://localhost:8081/home'
        }
        failure {
            echo '💥 El proceso falló en alguna etapa. Aplicando apagado preventivo...'
            dir('docker') {
                sh "docker-compose -p ${DOCKER_PROJECT_NAME} down -v || true"
            }
        }
    }
}